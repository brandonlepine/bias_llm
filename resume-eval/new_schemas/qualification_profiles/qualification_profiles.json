{
  "schema_version": "0.1.0",
  "description": "Multidimensional, independently-controllable candidate-quality profiles. Quality is NOT encoded in resume_backbones (which hold raw materials only); a profile selects WHICH materials and HOW MANY. Each profile must be compatible with a job's resume_generation_axes (experience_level/domain_match_level) before it is used with that job.",
  "dimension_levels": ["low", "moderate", "high"],
  "selection_semantics": {
    "school_prestige_tier": "1 = most selective; generator maps tier -> prestige-ordered education_pool index",
    "domain_proximity": "direct|adjacent|general -> generator maps to the job-appropriate backbone experience_pool",
    "years_experience_band": "internship_only|0_to_2_years|3_to_5_years|5_to_10_years|10_plus_years -> number of roles + dating",
    "skills_overlap": "fraction of the job's required+preferred skills surfaced in the SKILLS section",
    "project_relevance": "none|some|strong -> number/relevance of PROJECTS bullets",
    "communication_evidence": "low|moderate|high -> presence of presentation/writing/cross-functional language",
    "leadership_evidence": "low|moderate|high -> presence of lead/mentor/ownership language"
  },
