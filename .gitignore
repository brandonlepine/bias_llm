*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/

# Local configuration and secrets
.env
.env.*
!.env.example
*.pem
*.key
credentials.json

# OS/editor noise
.DS_Store
.idea/
.vscode/

# Large local artifacts
models/
results/
data/bbq/*
!data/bbq/data/
!data/bbq/data/*.jsonl
!data/bbq/few_shot_pool.json
!data/bbq/results/
data/bbq/results/*
# Track the generated patching-pair CSVs for EVERY category (these are what the pod
# needs), but nothing else under results/ (scored/candidates/plots stay local).
!data/bbq/results/*/
data/bbq/results/*/*
!data/bbq/results/*/patching_pairs/
data/bbq/results/*/patching_pairs/*
!data/bbq/results/*/patching_pairs/*.csv
# BBQ-derived WinoQueer-style stereotype datasets: track the reviewable curated predicates,
# the flat stereotype worklist, and the built pairs (the dataset). Plots/scored stay local.
!data/bbq/stereotypes/
data/bbq/stereotypes/*
!data/bbq/stereotypes/bbq_stereotypes_raw.csv
!data/bbq/stereotypes/bbq_predicates_curated.csv
!data/bbq/stereotypes/bbq_pairs_all.csv
!data/bbq/stereotypes/bbq_review_cards.csv
!data/bbq/stereotypes/bbq_review_cards.jsonl
!data/bbq/stereotypes/bbq_review_annotations.jsonl
# BBQ candidates for the new pipeline (mirror the patching_pairs carve-out above)
!data/bbq/results/*/patching_candidates/
data/bbq/results/*/patching_candidates/*
!data/bbq/results/*/patching_candidates/*.csv
data/bbq/.git/
# WinoQueer: the `results/` rule above ignores data/winoqueer/results/, but the pod needs
# the patching-candidate CSVs as input. Track only those (other results stay local).
!data/winoqueer/results/
data/winoqueer/results/*
!data/winoqueer/results/patching_candidates/
data/winoqueer/results/patching_candidates/*
!data/winoqueer/results/patching_candidates/*.csv
# The frozen, balanced segmented cohort is the pod input for the identity-segmented run-scripts.
# Track the cohort + its coverage report; nothing else.
!data/winoqueer/results/segmented/
data/winoqueer/results/segmented/*
!data/winoqueer/results/segmented/cohort.csv
!data/winoqueer/results/segmented/cohort_coverage.csv
status_mi_runpod_results/
status_mi_runpod_diagnostics_fast/
status_mi_runpod_diagnostics_fast_figures/
status_mi_runpod_figures_latest/
checkpoints/
wandb/
runs/

# Logs and temporary files
*.log
tmp/
temp/

# Keep source data and generated prompt CSVs trackable unless explicitly ignored later.
!data/mi_identity_prompts.csv

# Per-row audit artifact from scripts/audit_identity_spans.py; regeneratable.
data/find_identity_span_audit.csv
status_mi_runpod_figures_latest/
output_data/**
pod_results/**
winoqueer/**
# Upstream WinoQueer source repo (cloned locally, not ours to track)
/winoqueer/
